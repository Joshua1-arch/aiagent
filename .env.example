# Required: Base64-encoded onchainos session (from ~/.onchainos/session.json)
SESSION_JSON_CONTENT=<base64 of session.json>

# Required: Base64-encoded wallet config (from ~/.onchainos/wallets.json)
WALLETS_JSON_CONTENT=<base64 of wallets.json>

# Optional: Port for health check server (default 3000)
PORT=3000
